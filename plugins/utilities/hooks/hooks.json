{
    "hooks": {
        "Notification": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "sh -c 'notify-send \"Claude Code\" \"Notification\" --icon=utilities-terminal --app-name=\"Claude Code\"'"
                    }
                ]
            }
        ],
        "Stop": [
            {
                "hooks": [
